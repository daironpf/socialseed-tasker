# =============================================================================
# Tasker Configuration
# =============================================================================
# Copy this file to .env and configure for your environment

# =============================================================================
# NEO4J CONFIGURATION
# =============================================================================
# Toggle between LOCAL (Docker) and AURA (cloud) modes

# --- MODE: LOCAL (Docker) ---
# Default ports: 7687 (Bolt), 7474 (HTTP)
TASKER_NEO4J_URI=bolt://localhost:7687
TASKER_NEO4J_USER=neo4j
TASKER_NEO4J_PASSWORD=neoSocial

# --- MODE: AURA (Neo4j Cloud) ---
# Uncomment and configure for Neo4j Aura DB
# TASKER_NEO4J_URI=bolt+s://your-aura-id.databases.neo4j.io:7687
# TASKER_NEO4J_USER=neo4j
# TASKER_NEO4J_PASSWORD=your_aura_password

# =============================================================================
# API CONFIGURATION
# =============================================================================
TASKER_API_HOST=0.0.0.0
TASKER_API_PORT=8000

# =============================================================================
# AUTHENTICATION (Optional - for production)
# =============================================================================
# Uncomment to enable API authentication
# TASKER_AUTH_ENABLED=true
# TASKER_API_KEY=your-secret-api-key

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
# Default: 100 requests per minute
# TASKER_RATE_LIMIT=100

# =============================================================================
# DEMO MODE (Optional)
# =============================================================================
# Set to true to load demo data on startup
# TASKER_DEMO_MODE=false

# =============================================================================
# GITHUB INTEGRATION (Optional)
# =============================================================================
# Uncomment for GitHub sync features
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=owner/repository
# GITHUB_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# TASKER API URL (for external tools)
# =============================================================================
TASKER_API_URL=http://localhost:8000