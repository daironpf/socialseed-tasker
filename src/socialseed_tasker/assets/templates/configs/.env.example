# Neo4j Configuration
# Toggle between LOCAL (Docker) and AURA (remote) modes

# --- MODE: LOCAL ---
# Use this when running Neo4j via docker-compose
# Note: Default ports are 17689 (Bolt) and 18082 (HTTP) to avoid conflicts
TASKER_STORAGE_BACKEND=neo4j
TASKER_NEO4J_URI=bolt://localhost:17689
TASKER_NEO4J_USER=neo4j
TASKER_NEO4J_PASSWORD=tasker_password

# --- MODE: AURA ---
# Uncomment and configure for Neo4j Aura DB
# TASKER_STORAGE_BACKEND=neo4j
# TASKER_NEO4J_URI=bolt+s://your-aura-id.databases.neo4j.io:7687
# TASKER_NEO4J_USER=neo4j
# TASKER_NEO4J_PASSWORD=your_aura_password

# API Configuration
TASKER_API_HOST=0.0.0.0
TASKER_API_PORT=8000
TASKER_API_RELOAD=false
TASKER_DEBUG=false

# Tasker Skill Configuration
TASKER_API_URL=http://localhost:8000
